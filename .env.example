# Hermes Mobile Capture BFF local/staging configuration
# Copy to .env locally if you wrap the Python server with a process manager.

# Path to Hermes home where the mobile-capture HMAC secret lives.
# Never commit the real secret file.
HERMES_HOME=/path/to/.hermes

# BFF bind config
MOBILE_CAPTURE_HOST=127.0.0.1
MOBILE_CAPTURE_PORT=8650

# Optional explicit paths
MOBILE_CAPTURE_SECRET_FILE=/path/to/.hermes/mobile-capture-v1-secret.txt
MOBILE_CAPTURE_LEDGER=backend/data/mobile_capture_ledger.sqlite

# Public-safe placeholder. Replace locally with your tailnet DNS name.
TAILSCALE_DNS_NAME=your-node.your-tailnet.ts.net
